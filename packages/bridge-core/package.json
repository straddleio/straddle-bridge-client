{
    "name": "@straddlecom/bridge-core",
    "version": "1.0.0",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/straddleio/straddle-bridge-client.git",
        "directory": "packages/bridge-core"
    },
    "main": "dist/index.js",
    "module": "dist/index.js",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/types.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "import": "./dist/types.js"
        }
    },
    "types": "dist/types.d.ts",
    "scripts": {
        "build": "tsc",
        "dev": "npm-watch",
        "publish": "bun run build && bunx --bun npm publish"
    },
    "files": [
        "dist/**/*"
    ],
    "devDependencies": {
        "npm-watch": "^0.13.0",
        "typescript": "^5"
    },
    "watch": {
        "build": {
            "patterns": [
                "src"
            ],
            "extensions": "ts,tsx"
        }
    },
    "description": "Straddle Bridge Core library",
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/straddleio/straddle-bridge-client/issues"
    },
    "homepage": "https://github.com/straddleio/straddle-bridge-client#readme"
}
